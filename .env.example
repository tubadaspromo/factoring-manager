VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Payout Gateway ──────────────────────────────────────────────────────────
# Usado APENAS pelas Edge Functions (Deno) — NÃO pelo frontend.
# Adicione como segredos em: Supabase Dashboard → Edge Functions → Secrets
#   PAYOUT_SECRET  → chave secreta (usada em Basic Auth: base64(SECRET:x))
#   PAYOUT_CLIENT_ID → chave pública (opcional, para referência)
PAYOUT_CLIENT_ID=your_payout_public_key_here
PAYOUT_SECRET=your_payout_secret_key_here
